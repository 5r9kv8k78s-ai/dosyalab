APP_NAME=DosyaLab API
ENVIRONMENT=development

# Comma-separated list of allowed frontend origins. In production, set this
# to your deployed frontend's exact origin (e.g. a Vercel URL) — leaving it
# at the localhost default means the browser will block every request from
# the real frontend (backend stays "healthy", frontend just shows offline).
CORS_ORIGINS=http://localhost:3000

# Optional regex for origins you can't pin to one exact value, e.g. Vercel
# preview URLs (a new one per branch/PR). Scope it to your own project:
# CORS_ORIGIN_REGEX=https://dosyalab.*\.vercel\.app
CORS_ORIGIN_REGEX=

UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=25

CONVERT_UPLOAD_DIR=storage/convert/uploads
CONVERT_OUTPUT_DIR=storage/convert/outputs
MAX_CONVERT_UPLOAD_SIZE_MB=100

# Caps the number of files accepted in one multi-file request (merge-pdf,
# images-to-pdf) — a per-file size cap alone still permits an abusive batch
# total (e.g. hundreds of near-100MB files in one request).
MAX_BATCH_FILE_COUNT=30

JOB_TTL_MINUTES=60
CLEANUP_INTERVAL_MINUTES=10

# Conversion/upload rate limiting (see app/services/rate_limiter.py).
# Process-local, fixed-window, in-memory — resets on restart and is
# enforced PER REPLICA if this API is ever scaled horizontally. A shared
# (e.g. Redis-backed) limiter is a real production requirement before
# running more than one replica behind a load balancer.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Privacy-safe operational event tracking for the future Admin Panel (see
# app/services/operations_events.py). Never stores filenames, file
# content, document text, or raw IP addresses — only aggregate counters
# (tool used, success/failure, duration, stable error category). In-memory
# only: lost on restart, per-replica, and bounded by both settings below.
# A real datastore is required before this is relied on for production
# reporting.
OPERATIONS_EVENTS_ENABLED=true
OPERATIONS_EVENTS_MAX_COUNT=5000
OPERATIONS_EVENTS_RETENTION_SECONDS=604800
