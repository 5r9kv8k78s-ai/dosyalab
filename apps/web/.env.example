NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical public site URL — consumed by app/layout.tsx (metadataBase),
# app/robots.ts, app/sitemap.ts, and app/opengraph-image.tsx (see
# lib/seo/siteUrl.ts). Falls back to http://localhost:3000 if unset. Set
# this to DosyaLab's real production domain, not a throwaway Vercel preview
# URL — otherwise canonical links, the sitemap, and Open Graph/Twitter
# metadata will point at a deployment that may not exist tomorrow.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin Panel authentication (Supabase Auth) — see lib/supabase/,
# middleware.ts, app/admin/. Both of these are intentionally public
# browser configuration (Supabase's anon key is designed to be exposed
# client-side; it has no access without a valid user session and Supabase's
# own row-level security). NEVER put the service-role key or a database
# connection string in a NEXT_PUBLIC_ variable — those stay backend-only,
# see apps/api/.env.example.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
