# Variables consumed by docker-compose.yml itself (compose interpolation).
# Per-app runtime config lives in apps/web/.env and apps/api/.env —
# copy their .env.example files too.
#
# Deploying frontend and backend separately (e.g. Vercel + Render)? These
# two must agree with each other: NEXT_PUBLIC_API_URL is the backend's real
# URL, and CORS_ORIGINS on the backend must include the frontend's real URL.
# Mismatching either one causes the frontend to show "Backend Offline" even
# though the backend itself is up — see apps/api/.env.example for details
# (including CORS_ORIGIN_REGEX for Vercel preview URLs).

CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
