{
  "name": "dosyalab",
  "private": true,
  "version": "0.1.0",
  "description": "DosyaLab monorepo — document conversion platform",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter dosyalab-web dev",
    "build": "pnpm --filter dosyalab-web build",
    "lint": "pnpm --filter dosyalab-web lint",
    "format": "prettier --write \"apps/web/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"apps/web/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
